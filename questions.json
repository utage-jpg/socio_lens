[
  { "id": 1,  "text": "「なんとなくこうなりそう」という感覚で物事の見通しを話すことがある。", "im": "Ni", "reversed": false, "category": "im_direct" },
  { "id": 2,  "text": "今起きていることより「これがどこへ向かうか」という話のほうが活き活きして見える。", "im": "Ni", "reversed": false, "category": "im_direct" },
  { "id": 3,  "text": "自分の予感や直感を、あまり説明せずそのまま信じて行動することがある。", "im": "Ni", "reversed": false, "category": "im_direct" },
  { "id": 4,  "text": "じっくり待つことや、流れに身を任せることを自然と好んでいるように見える。", "im": "Ni", "reversed": false, "category": "im_direct" },
  { "id": 5,  "text": "話しているうちに「そういえばこういう可能性もある」と話題を広げることがよくある。", "im": "Ne", "reversed": false, "category": "im_direct" },
  { "id": 6,  "text": "アイデアや思いつきを次々と出すことを、楽しそうにやっている。", "im": "Ne", "reversed": false, "category": "im_direct" },
  { "id": 7,  "text": "まだ形になっていない構想や可能性の話になると、目が輝くことがある。", "im": "Ne", "reversed": false, "category": "im_direct" },
  { "id": 8,  "text": "「一つのことに集中する」より「色々なことに関わる」ほうが向いているように見える。", "im": "Ne", "reversed": false, "category": "im_direct" },
  { "id": 9,  "text": "場所・食事・温度など、身の回りの快適さへのこだわりをよく口にする。", "im": "Si", "reversed": false, "category": "im_direct" },
  { "id": 10, "text": "体調や感覚の微妙な変化に敏感で、それをよく言語化する。", "im": "Si", "reversed": false, "category": "im_direct" },
  { "id": 11, "text": "慣れ親しんだ環境や習慣を、変えずに守ることを大切にしているように見える。", "im": "Si", "reversed": false, "category": "im_direct" },
  { "id": 12, "text": "騒がしい場所や落ち着かない環境では、明らかに消耗しているように見える。", "im": "Si", "reversed": false, "category": "im_direct" },
  { "id": 13, "text": "その場の主導権を、気づいたら自然と握っていることがある。", "im": "Se", "reversed": false, "category": "im_direct" },
  { "id": 14, "text": "「やるならやる」というはっきりした意志を、行動で示すことが多い。", "im": "Se", "reversed": false, "category": "im_direct" },
  { "id": 15, "text": "プレッシャーがかかる場面でも萎縮せず、むしろ力が出るように見える。", "im": "Se", "reversed": false, "category": "im_direct" },
  { "id": 16, "text": "物事をぐずぐず引き延ばすことを嫌い、すぐ動こうとする傾向がある。", "im": "Se", "reversed": false, "category": "im_direct" },
  { "id": 17, "text": "「それはどういう定義？」「そこに矛盾がある」という指摘を自然とする。", "im": "Ti", "reversed": false, "category": "im_direct" },
  { "id": 18, "text": "物事を分類・体系化して理解しようとする様子がよく見られる。", "im": "Ti", "reversed": false, "category": "im_direct" },
  { "id": 19, "text": "話の筋道が通っているかどうかを、自然と気にしているように見える。", "im": "Ti", "reversed": false, "category": "im_direct" },
  { "id": 20, "text": "論理の話になると迷いがなくなり、自信を持って話すように見える。", "im": "Ti", "reversed": false, "category": "im_direct" },
  { "id": 21, "text": "「実際どのくらい効果があるの？」「根拠はあるの？」という反応をしがちだ。", "im": "Te", "reversed": false, "category": "im_direct" },
  { "id": 22, "text": "無駄な手順や非効率なやり方を放置できず、改善しようとすることが多い。", "im": "Te", "reversed": false, "category": "im_direct" },
  { "id": 23, "text": "目標や成果が明確な話のほうが、乗り気になりやすい。", "im": "Te", "reversed": false, "category": "im_direct" },
  { "id": 24, "text": "感情的な話より「実際に機能するかどうか」で評価する場面が目立つ。", "im": "Te", "reversed": false, "category": "im_direct" },
  { "id": 25, "text": "好きな人と苦手な人がはっきりしていて、それをあまり表に出さない。", "im": "Fi", "reversed": false, "category": "im_direct" },
  { "id": 26, "text": "人との関係の深さや「本当に信頼できるか」を、静かにじっくり確かめるように見える。", "im": "Fi", "reversed": false, "category": "im_direct" },
  { "id": 27, "text": "自分の感情や価値観を、内側で十分確かめてから言葉にすることが多い。", "im": "Fi", "reversed": false, "category": "im_direct" },
  { "id": 28, "text": "表面的な付き合いより、少数の深い人間関係を大切にしているように見える。", "im": "Fi", "reversed": false, "category": "im_direct" },
  { "id": 29, "text": "場の雰囲気を明るくしたり和ませたりする役割を、自然と担っていることが多い。", "im": "Fe", "reversed": false, "category": "im_direct" },
  { "id": 30, "text": "喜怒哀楽が表情や言葉ににじみ出やすく、感情が周囲に伝わりやすい。", "im": "Fe", "reversed": false, "category": "im_direct" },
  { "id": 31, "text": "誰かの気分が落ちているとすぐ気づき、その場の空気を変えようとする。", "im": "Fe", "reversed": false, "category": "im_direct" },
  { "id": 32, "text": "感情を共有することや、一緒に盛り上がることをとても大切にしているように見える。", "im": "Fe", "reversed": false, "category": "im_direct" },

  { "id": 33, "text": "特に目的がなくても、アイデアや雑談を純粋に楽しむだけの会話をとても大切にしているように見える。", "im": null, "quadra": "Alpha", "reversed": false, "category": "quadra" },
  { "id": 34, "text": "堅苦しい上下関係よりも、フラットで和やかな雰囲気の場をより好むように見える。", "im": null, "quadra": "Alpha", "reversed": false, "category": "quadra" },
  { "id": 35, "text": "話の内容が面白いかどうか・知的に楽しいかどうかを、かなり重視しているように見える。", "im": null, "quadra": "Alpha", "reversed": false, "category": "quadra" },
  { "id": 36, "text": "何かに本気で取り組む時、強い使命感や「自分がやらねば」という意識を感じさせる。", "im": null, "quadra": "Beta", "reversed": false, "category": "quadra" },
  { "id": 37, "text": "物事の「大きな流れ」や「この時代における意味」のような話に深く引き込まれることがある。", "im": null, "quadra": "Beta", "reversed": false, "category": "quadra" },
  { "id": 38, "text": "はっきりとした立場や信念を持ち、それを軸に行動することが多い。", "im": null, "quadra": "Beta", "reversed": false, "category": "quadra" },
  { "id": 39, "text": "結果や実績で評価されることを好み、プロセスよりも成果にこだわる傾向がある。", "im": null, "quadra": "Gamma", "reversed": false, "category": "quadra" },
  { "id": 40, "text": "自分のやり方や領域に他者が踏み込んでくることを、あまり好まないように見える。", "im": null, "quadra": "Gamma", "reversed": false, "category": "quadra" },
  { "id": 41, "text": "「強い人間・自立した人間」であることへの意識が、言動の端々に感じられる。", "im": null, "quadra": "Gamma", "reversed": false, "category": "quadra" },
  { "id": 42, "text": "競争や比較に対して、回避するより正面から向き合う傾向がある。", "im": null, "quadra": "Gamma", "reversed": false, "category": "quadra" },
  { "id": 43, "text": "身近な人の生活や日常を少しよくするような、地に足のついた行動を大切にしている。", "im": null, "quadra": "Delta", "reversed": false, "category": "quadra" },
  { "id": 44, "text": "大きな理想を語るよりも、今できる具体的な改善を考えることのほうが好きに見える。", "im": null, "quadra": "Delta", "reversed": false, "category": "quadra" },
  { "id": 45, "text": "特定の人との深い信頼関係を、何よりも大切にしているように見える。", "im": null, "quadra": "Delta", "reversed": false, "category": "quadra" },
  { "id": 46, "text": "自分や身近な人が「実際に心地よく暮らせるか」という視点で物事を判断することが多い。", "im": null, "quadra": "Delta", "reversed": false, "category": "quadra" },

  { "id": 47, "text": "この人のことを、自分はよく理解していると思う。", "im": null, "reversed": false, "category": "reliability" },
  { "id": 48, "text": "この人の行動や発言は、場面によってかなり変わり、一貫性がつかみにくいと感じる。", "im": null, "reversed": true, "category": "reliability" },
  { "id": 49, "text": "この人と過ごした具体的な場面を、いくつか思い浮かべながら回答できた。", "im": null, "reversed": false, "category": "reliability" },
  { "id": 50, "text": "この人のことを思い浮かべながら答えるのが、途中から難しくなった。", "im": null, "reversed": true, "category": "reliability" }
]
